# Supabase connection string for backend database
# Replace values with your Supabase project settings
DATABASE_URL=postgresql://postgres:<YOUR_PASSWORD>@<YOUR_PROJECT_REF>.supabase.co:5432/postgres

# Firebase Admin SDK fallback configuration
# Use these only if backend/firebase-service-account.json is not present
FIREBASE_PROJECT_ID=roadresq-cdef7
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@roadresq-cdef7.iam.gserviceaccount.com

PORT=4000
CORS_ORIGIN=*

# Real online payment gateway for Soteria Credits top-ups.
# Use PayMongo test keys while developing, then replace with live keys after go-live approval.
PAYMONGO_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYMONGO_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYMONGO_SIGNATURE_MODE=test

# Responder payout automation.
# simulated = instant test payout records, manual = queue for admin processing,
# live providers can be wired here once PayMongo Money Movement/Disbursements is enabled.
PAYOUT_PROVIDER=simulated
RESPONDER_PAYOUT_TRANSFER_FEE=10
COMMUNITY_PAYOUT_TRANSFER_FEE=10
# Prevent tiny InstaPay payouts that can be rejected by receiving wallets.
RESPONDER_MIN_PAYOUT_AMOUNT=10

# PayMongo Wallet Transfers for real responder payouts.
# Enable with PAYOUT_PROVIDER=paymongo only after your wallet has available balance.
PAYMONGO_WALLET_ID=wallet_xxxxxxxxxxxxxxxxxxxxxxxx
PAYMONGO_WALLET_TRANSFER_PROVIDER=instapay
PAYMONGO_GCASH_BIC=GXCHPHM2XXX
PAYMONGO_WALLET_TRANSFER_CALLBACK_URL=
RESPONDER_PAYOUT_RETRY_DELAY_MS=600000
RESPONDER_PAYOUT_WORKER_INTERVAL_MS=300000
RESPONDER_PAYOUT_MAX_ATTEMPTS=3
